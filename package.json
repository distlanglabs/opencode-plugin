{
  "name": "@distlang/opencode-plugin",
  "version": "0.1.3",
  "description": "OpenCode plugin for Distlang AI Debugger",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "node --check src/index.js && node --check src/recorder.js && node --check src/distlang.js && node --check src/state.js && node --check src/command.js",
    "check": "npm test",
    "pack:check": "npm pack --dry-run",
    "release": "npm test && npm run pack:check",
    "publish": "npm publish --access public"
  },
  "keywords": [
    "distlang",
    "opencode",
    "plugin",
    "ai-debugger"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/distlanglabs/opencode-plugin.git"
  },
  "homepage": "https://github.com/distlanglabs/opencode-plugin#readme",
  "bugs": {
    "url": "https://github.com/distlanglabs/opencode-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
